      "tar": ">=7.5.11",
      "fast-xml-parser": ">=5.5.7",
      "lodash": ">=4.17.23",
      "simple-git": ">=3.28.0",
      "rollup": ">=4.40.0",
      "flatted": ">=3.3.3",
      "minimatch": ">=10.0.0",
      "serialize-javascript": ">=6.0.3",
      "undici": ">=7.10.0",
      "svgo": ">=3.4.0"
    }
