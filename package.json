{
  "name": "nuxt-jpp-domain-checker",
  "private": false,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "wrangler pages dev .output/public",
    "deploy": "wrangler pages deploy .output/public --project-name domain-checker",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@iconify-json/circle-flags": "^1.2.10",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.82",
    "@nuxt/icon": "^2.2.2",
    "@nuxt/ui": "^4.7.1",
    "@nuxtjs/seo": "5.1.3",
    "@vercel/analytics": "^2.0.1",
    "nuxt": "^4.4.5"
  },
  "devDependencies": {
    "@nuxt/devtools": "4.0.0-alpha.4",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/i18n": "^10.3.0",
    "@vitest/coverage-v8": "^4.1.6",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.3.0",
    "happy-dom": "^20.9.0",
    "nuxt-security": "^2.6.0",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.9",
    "wrangler": "^4.91.0",
    "zod": "^4.4.3"
  },
  "pnpm": {
